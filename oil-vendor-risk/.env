# ── LLM Backend ──────────────────────────────────────────────────────────────
# Your AMD ROCm / vLLM server exposes an OpenAI-compatible endpoint locally.
# Change the base URL if your vLLM instance runs on a different port.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3   # or whatever model you loaded

# If you prefer Azure OpenAI, fill these instead and set USE_AZURE=true
USE_AZURE=false
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=7860
LOG_LEVEL=info
