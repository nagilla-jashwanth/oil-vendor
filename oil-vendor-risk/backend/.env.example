# Copy this to .env and fill in your values

# vLLM endpoint (running locally on your AMD GPU instance)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Optional: Tavily Search API (free tier available at https://tavily.com)
# Gives better structured web results than DuckDuckGo
TAVILY_API_KEY=

# App settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
